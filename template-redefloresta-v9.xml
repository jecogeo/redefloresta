<?xml version="1.0" encoding="UTF-8"?>
<mdb:MD_Metadata xmlns:mdb="http://standards.iso.org/iso/19115/-3/mdb/2.0"
                 xmlns:mri="http://standards.iso.org/iso/19115/-3/mri/1.0"
                 xmlns:cit="http://standards.iso.org/iso/19115/-3/cit/2.0"
                 xmlns:gex="http://standards.iso.org/iso/19115/-3/gex/1.0"
                 xmlns:mcc="http://standards.iso.org/iso/19115/-3/mcc/1.0"
                 xmlns:mrd="http://standards.iso.org/iso/19115/-3/mrd/1.0"
                 xmlns:mdq="http://standards.iso.org/iso/19115/-3/mdq/1.0"
                 xmlns:mrl="http://standards.iso.org/iso/19115/-3/mrl/2.0"
                 xmlns:mco="http://standards.iso.org/iso/19115/-3/mco/1.0"
                 xmlns:mrs="http://standards.iso.org/iso/19115/-3/mrs/1.0"
                 xmlns:mrc="http://standards.iso.org/iso/19115/-3/mrc/2.0"
                 xmlns:lan="http://standards.iso.org/iso/19115/-3/lan/1.0"
                 xmlns:gco="http://standards.iso.org/iso/19115/-3/gco/1.0"
                 xmlns:gml="http://www.opengis.net/gml/3.2">

  <mdb:metadataIdentifier>
    <mcc:MD_Identifier><mcc:code><gco:CharacterString/></mcc:code></mcc:MD_Identifier>
  </mdb:metadataIdentifier>
  <mdb:defaultLocale>
    <lan:PT_Locale>
      <lan:language><lan:LanguageCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/lan/LanguageCode.xml" codeListValue="por"/></lan:language>
      <lan:characterEncoding><lan:MD_CharacterSetCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/lan/MD_CharacterSetCode.xml" codeListValue="utf8"/></lan:characterEncoding>
    </lan:PT_Locale>
  </mdb:defaultLocale>

  <mdb:identificationInfo>
    <mri:MD_DataIdentification>
      <mri:citation>
        <cit:CI_Citation>
          <cit:title><gco:CharacterString/></cit:title>
          <cit:date>
            <cit:CI_Date>
              <cit:date><gco:DateTime/></cit:date>
              <cit:dateType><cit:CI_DateTypeCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/cit/CI_DateTypeCode.xml" codeListValue="creation"/></cit:dateType>
            </cit:CI_Date>
          </cit:date>
        </cit:CI_Citation>
      </mri:citation>
      <mri:abstract><gco:CharacterString/></mri:abstract>

      <!-- Palavras-chave (Tema) -->
      <mri:descriptiveKeywords>
        <mri:MD_Keywords>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:type><mri:MD_KeywordTypeCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/mri/MD_KeywordTypeCode.xml" codeListValue="theme"/></mri:type>
        </mri:MD_Keywords>
      </mri:descriptiveKeywords>

      <!-- Palavras-chave (Local) -->
      <mri:descriptiveKeywords>
        <mri:MD_Keywords>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:keyword><gco:CharacterString/></mri:keyword>
          <mri:type><mri:MD_KeywordTypeCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/mri/MD_KeywordTypeCode.xml" codeListValue="place"/></mri:type>
        </mri:MD_Keywords>
      </mri:descriptiveKeywords>

      <mri:extent>
        <gex:EX_Extent>
          <gex:geographicElement>
            <gex:EX_GeographicBoundingBox>
              <gex:westBoundLongitude><gco:Decimal/></gex:westBoundLongitude>
              <gex:eastBoundLongitude><gco:Decimal/></gex:eastBoundLongitude>
              <gex:southBoundLatitude><gco:Decimal/></gex:southBoundLatitude>
              <gex:northBoundLatitude><gco:Decimal/></gex:northBoundLatitude>
            </gex:EX_GeographicBoundingBox>
          </gex:geographicElement>
          <gex:temporalElement>
            <gex:EX_TemporalExtent>
              <gex:extent><gml:TimePeriod gml:id="t1"><gml:beginPosition/><gml:endPosition/></gml:TimePeriod></gex:extent>
            </gex:EX_TemporalExtent>
          </gex:temporalElement>
        </gex:EX_Extent>
      </mri:extent>

      <!-- 2.1 Escala Cartográfica -->
      <mri:spatialResolution>
        <mri:MD_Resolution>
          <mri:equivalentScale>
            <mri:MD_RepresentativeFraction>
              <mri:denominator><gco:Integer/></mri:denominator>
            </mri:MD_RepresentativeFraction>
          </mri:equivalentScale>
        </mri:MD_Resolution>
      </mri:spatialResolution>

      <!-- 2.1 Resolução Espacial (metros) -->
      <mri:spatialResolution>
        <mri:MD_Resolution>
          <mri:distance>
            <gco:Distance uom="m"/>
          </mri:distance>
        </mri:MD_Resolution>
      </mri:spatialResolution>

      <mri:status><mcc:MD_ProgressCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/mcc/MD_ProgressCode.xml" codeListValue=""/></mri:status>
      <mri:resourceConstraints><mco:MD_LegalConstraints><mco:useLimitation><gco:CharacterString/></mco:useLimitation></mco:MD_LegalConstraints></mri:resourceConstraints>
    </mri:MD_DataIdentification>
  </mdb:identificationInfo>

  <!-- 2.4 Atributos (Dicionário de Dados) - Seção Content Info com Supplemental Information -->
  <mdb:contentInfo>
    <mrc:MD_FeatureCatalogueDescription>
      <mrc:featureCatalogueCitation>
        <cit:CI_Citation>
          <cit:title><gco:CharacterString>Dicionario de Dados - Atributos</gco:CharacterString></cit:title>
        </cit:CI_Citation>
      </mrc:featureCatalogueCitation>
      <mrc:featureTypes>
        <mrc:MD_FeatureTypeInfo>
          <mrc:featureTypeName><gco:CharacterString/></mrc:featureTypeName>
        </mrc:MD_FeatureTypeInfo>
      </mrc:featureTypes>
    </mrc:MD_FeatureCatalogueDescription>
    <!-- Supplemental Information como campo textarea para os atributos -->
    <mri:supplementalInformation>
      <gco:CharacterString/>
    </mri:supplementalInformation>
  </mdb:contentInfo>

  <mdb:dataQualityInfo>
    <mdq:DQ_DataQuality><mdq:lineage><mrl:LI_Lineage><mrl:statement><gco:CharacterString/></mrl:statement></mrl:LI_Lineage></mdq:lineage></mdq:DQ_DataQuality>
  </mdb:dataQualityInfo>

  <mdb:referenceSystemInfo>
    <mrs:MD_ReferenceSystem><mrs:referenceSystemIdentifier><mcc:MD_Identifier><mcc:code><gco:CharacterString/></mcc:code></mcc:MD_Identifier></mrs:referenceSystemIdentifier></mrs:MD_ReferenceSystem>
  </mdb:referenceSystemInfo>

  <mdb:contact>
    <cit:CI_Responsibility>
      <cit:role><cit:CI_RoleCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/cit/CI_RoleCode.xml" codeListValue="pointOfContact"/></cit:role>
      <cit:party><cit:CI_Organisation><cit:name><gco:CharacterString/></cit:name></cit:CI_Organisation></cit:party>
      <cit:contactInfo><cit:CI_Contact><cit:address><cit:CI_Address><cit:electronicMailAddress><gco:CharacterString/></cit:electronicMailAddress></cit:CI_Address></cit:address></cit:CI_Contact></cit:contactInfo>
    </cit:CI_Responsibility>
  </mdb:contact>

  <mdb:distributionInfo>
    <mrd:MD_Distribution>
      <mrd:distributionFormat><mrd:MD_Format><mrd:formatSpecificationCitation><cit:CI_Citation><cit:title><gco:CharacterString/></cit:title></cit:CI_Citation></mrd:formatSpecificationCitation></mrd:MD_Format></mrd:distributionFormat>
      <mrd:transferOptions>
        <mrd:MD_DigitalTransferOptions>
          <mrd:onLine>
            <cit:CI_OnlineResource>
              <cit:linkage><gco:CharacterString/></cit:linkage>
              <cit:protocol><gco:CharacterString>WWW:DOWNLOAD-1.0-http--download</gco:CharacterString></cit:protocol>
              <cit:name><gco:CharacterString>Download do Recurso</gco:CharacterString></cit:name>
              <cit:function><cit:CI_OnLineFunctionCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/cit/CI_OnLineFunctionCode.xml" codeListValue="download"/></cit:function>
            </cit:CI_OnlineResource>
          </mrd:onLine>
          <mrd:onLine>
            <cit:CI_OnlineResource>
              <cit:linkage><gco:CharacterString/></cit:linkage>
              <cit:protocol><gco:CharacterString>OGC:WMS</gco:CharacterString></cit:protocol>
              <cit:name><gco:CharacterString>Servico WMS</gco:CharacterString></cit:name>
              <cit:function><cit:CI_OnLineFunctionCode codeList="http://standards.iso.org/iso/19115/resources/Codelist/cit/CI_OnLineFunctionCode.xml" codeListValue="information"/></cit:function>
            </cit:CI_OnlineResource>
          </mrd:onLine>
        </mrd:MD_DigitalTransferOptions>
      </mrd:transferOptions>
    </mrd:MD_Distribution>
  </mdb:distributionInfo>

</mdb:MD_Metadata>
